generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  password    String
  age         Int?
  phoneNumber String
}

model Food {
  id             Int             @id @default(autoincrement())
  name           String
  price          String
  category       FoodCategory    @relation(fields: [foodCategoryId], references: [id])
  foodCategoryId Int
  // foodOrderItems FoodOrderItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model FoodCategory {
  id        Int     @id @default(autoincrement())
  name      String
  foods     Food[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FoodOrder {
  id             Int             @id @default(autoincrement())
  totalPrice     String
  status         String
  // foodOrderItems FoodOrderItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

