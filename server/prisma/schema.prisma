datasource db {
  provider = "postgresql"
  ls
  
}

generator client {
  provider = "prisma-client-js"
}
enum Role {
  User
  Admin
}

enum Status {
  PENDING
  CANCELED
  DELIVERED
}


model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  password     String
  age          Int?
  phoneNumber  String
  // address      String
  // role         String
  // orderedFoods String

}

model Food {
  id             Int             @id @default(autoincrement())
  name           String
  price          String
  category       FoodCategory    @relation(fields: [foodCategoryId], references: [id])
  image          String          @default("NULL")
  ingredients    String          @default("NULL")
  foodCategoryId Int
  foodOrderItems FoodOrderItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model FoodCategory {
  id        Int     @id @default(autoincrement())
  name      String
  foods     Food[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FoodOrder {
  id             Int             @id @default(autoincrement())
  totalPrice     String
  // userId  User @relation(fields: [],references: [id])
  status         Status @default(PENDING)
  foodOrderItems FoodOrderItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model FoodOrderItem {
  id          Int       @id @default(autoincrement())
  quantity    Int
  food        Food      @relation(fields: [foodId], references: [id])
  foodId      Int
  order       FoodOrder @relation(fields: [foodOrderId], references: [id])
  foodOrderId Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}